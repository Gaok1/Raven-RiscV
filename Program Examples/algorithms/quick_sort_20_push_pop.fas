# quick_sort_20_push_pop.fas — Quicksort (recursive, Lomuto partition scheme)
#
# Sorts 20 random integers using the classic recursive quicksort.
# The array is filled at run time via the Linux getrandom(2) syscall,
# so input differs on every execution.  Pivot = arr[hi] (last element).
#
# Demonstrates deep recursion with push/pop pseudo-instructions to preserve
# callee-saved registers (s0..s5) and ra across recursive calls.
#
# Average O(n log n); worst case O(n^2) on already-sorted input.

.data
arr: .space 80                      # 20 × 4-byte slots, filled at run time
lbl: .asciz "Sorted: "
sp2: .asciz " "

.text
    # Linux getrandom(2) — syscall 278:
    # fills the buffer with cryptographically-secure random bytes from
    # the kernel CSPRNG.  a0=buf, a1=len (bytes), a2=flags (0 = block
    # until the entropy pool is seeded; never returns stale data).
    la   a0, arr
    li   a1, 80                 # 20 elements × 4 bytes
    li   a2, 0
    li   a7, 278
    ecall

    # Reduce each raw 32-bit word to [1, 100] for readable output.
    la   t0, arr
    li   t1, 20
    li   t2, 0
reduce_loop:
    slli t3, t2, 2
    add  t3, t0, t3
    lw   t4, 0(t3)
    li   t5, 100
    remu t4, t4, t5
    addi t4, t4, 1
    sw   t4, 0(t3)
    addi t2, t2, 1
    blt  t2, t1, reduce_loop

    printStrLn lbl

    la   a0, arr
    li   a1, 0
    li   a2, 19
    call quicksort

    # Print sorted array space-separated
    la   t0, arr
    li   t4, 20
    li   t1, 0
print_loop:
    slli t2, t1, 2
    add  t2, t0, t2
    lw   a0, 0(t2)
    li   a7, 1000
    ecall
    li   a7, 1001
    la   a0, sp2
    ecall
    addi t1, t1, 1
    blt  t1, t4, print_loop
    li   a7, 1008
    ecall

    li   a0, 0
    li   a7, 93
    ecall


# quicksort(a0=base, a1=lo, a2=hi)
quicksort:
    bge  a1, a2, qs_done    # base case: empty or single-element range

    push ra
    push s1
    push s2
    push s3
    push s4

    mv   s1, a0             # s1 = array base pointer
    mv   s2, a1             # s2 = lo
    mv   s3, a2             # s3 = hi

    mv   a0, s1
    mv   a1, s2
    mv   a2, s3
    call partition
    mv   s4, a0             # s4 = pivot final index

    mv   a0, s1             # sort left half: [lo, pivot-1]
    mv   a1, s2
    addi a2, s4, -1
    call quicksort

    mv   a0, s1             # sort right half: [pivot+1, hi]
    addi a1, s4, 1
    mv   a2, s3
    call quicksort

    pop  s4
    pop  s3
    pop  s2
    pop  s1
    pop  ra
qs_done:
    ret


# partition(a0=base, a1=lo, a2=hi) → a0 = pivot final index
# Lomuto scheme: pivot = arr[hi]; all elements <= pivot go left.
partition:
    push ra
    push s0
    push s1
    push s2
    push s3
    push s4
    push s5

    mv   s1, a0             # s1 = base
    mv   s2, a1             # s2 = lo
    mv   s3, a2             # s3 = hi

    # Load pivot = arr[hi]
    slli t0, s3, 2
    add  t0, s1, t0
    lw   s0, 0(t0)          # s0 = pivot value

    addi s4, s2, -1         # i = lo-1 (boundary of "small" partition)
    mv   s5, s2             # j = lo

part_loop:
    bge  s5, s3, part_done  # j < hi

    slli t1, s5, 2
    add  t1, s1, t1
    lw   t2, 0(t1)          # arr[j]

    blt  s0, t2, skip_swap  # arr[j] > pivot: leave in right partition

    addi s4, s4, 1          # i++
    beq  s4, s5, skip_swap  # i == j: no swap needed

    slli t3, s4, 2
    add  t3, s1, t3
    lw   t4, 0(t3)          # arr[i]
    sw   t2, 0(t3)          # arr[i] = arr[j]
    sw   t4, 0(t1)          # arr[j] = old arr[i]

skip_swap:
    addi s5, s5, 1
    j    part_loop

part_done:
    addi t0, s4, 1          # pivot final position = i+1

    # Place pivot at its final position: swap arr[i+1] <-> arr[hi]
    slli t1, t0, 2
    add  t1, s1, t1
    lw   t2, 0(t1)

    slli t3, s3, 2
    add  t3, s1, t3
    lw   t4, 0(t3)

    sw   t4, 0(t1)
    sw   t2, 0(t3)

    mv   a0, t0             # return pivot index

    pop  s5
    pop  s4
    pop  s3
    pop  s2
    pop  s1
    pop  s0
    pop  ra
    ret
