# bubble_sort_20.fas — Bubble sort with swap counter and early-exit optimisation
#
# Sorts 20 integers in-place.  Each pass bubbles the largest unsorted element
# to the right.  If a pass produces zero swaps the array is already sorted —
# the early-exit makes best-case O(n) instead of O(n^2).
#
# Prints the sorted array on one line, then reports total swaps performed.

.data
arr:        .word 20, 1, 19, 2, 18, 3, 17, 4, 16, 5, 15, 6, 14, 7, 13, 8, 12, 9, 11, 10
lbl_sorted: .asciz "Sorted: "
lbl_swaps:  .asciz "Swaps:  "
space:      .asciz " "

.text
    la   t0, arr
    li   t1, 20             # n
    li   s2, 0              # total swap count
    mv   t4, t1             # unsorted length (shrinks each pass)

outer_loop:
    li   s3, 0              # swaps this pass
    li   t2, 0              # j = 0
    addi t5, t4, -1         # inner limit = unsorted_len - 1

inner_loop:
    bge  t2, t5, inner_done
    slli t3, t2, 2
    add  t3, t0, t3
    lw   s0, 0(t3)          # arr[j]
    lw   s1, 4(t3)          # arr[j+1]
    ble  s0, s1, no_swap    # already in order
    sw   s1, 0(t3)
    sw   s0, 4(t3)
    addi s2, s2, 1          # total_swaps++
    addi s3, s3, 1          # pass_swaps++
no_swap:
    addi t2, t2, 1
    j    inner_loop

inner_done:
    addi t4, t4, -1         # one more element is in its final position
    beq  s3, zero, sort_done   # early exit: no swaps → sorted
    bgt  t4, zero, outer_loop

sort_done:
    # Print sorted array on one line
    li   a7, 1001
    la   a0, lbl_sorted
    ecall
    li   t2, 0
print_loop:
    slli t3, t2, 2
    add  t3, t0, t3
    lw   a0, 0(t3)
    li   a7, 1000
    ecall
    li   a7, 1001
    la   a0, space
    ecall
    addi t2, t2, 1
    li   t6, 20
    blt  t2, t6, print_loop
    li   a7, 1008
    ecall

    # Print swap count
    li   a7, 1001
    la   a0, lbl_swaps
    ecall
    li   a7, 1000
    mv   a0, s2
    ecall
    li   a7, 1008
    ecall

    li   a0, 0
    li   a7, 93
    ecall
