# fatorial.fas — Iterative factorial using a raw stack frame (no push/pop pseudos)
#
# Computes n! for n read from stdin (valid range: 1..12; 13! overflows 32 bits).
# Demonstrates explicit stack manipulation:
#   addi sp, sp, -N   — allocate frame
#   sw   reg, off(sp) — spill register
#   lw   reg, off(sp) — reload register
#   addi sp, sp, +N   — deallocate frame
#
# Compare with fat_push_pop_pseudoinstructions.fas which does the same
# thing recursively using the push/pop shorthand.

.data
prompt:  .asciz "n (1..12): "
lbl_out: .asciz "n! = "
n_buf:   .space 4

.text
    li   a7, 1001
    la   a0, prompt
    ecall
    la   a0, n_buf
    li   a7, 1013           # read_int
    ecall

    la   t0, n_buf
    lw   a0, 0(t0)
    call factorial

    li   a7, 1001
    la   a0, lbl_out
    ecall
    li   a7, 1000
    mv   a0, s0             # result is in s0 by convention
    ecall
    li   a7, 1008
    ecall

    li   a0, 0
    li   a7, 93
    ecall


# factorial(a0=n) → s0 = n!
# Iterative: multiply 2*3*...*n into accumulator.
# Uses raw stack to save/restore s1 and ra.
factorial:
    addi sp, sp, -8
    sw   ra, 4(sp)          # save return address
    sw   s1, 0(sp)          # save s1 (will use as loop limit)

    mv   s1, a0             # s1 = n  (loop limit)
    li   s0, 1              # s0 = accumulator (also return register)
    li   t0, 2              # i = 2

fact_loop:
    bgt  t0, s1, fact_done
    mul  s0, s0, t0         # accumulator *= i
    addi t0, t0, 1
    j    fact_loop
fact_done:
    lw   s1, 0(sp)
    lw   ra, 4(sp)
    addi sp, sp, 8
    ret
