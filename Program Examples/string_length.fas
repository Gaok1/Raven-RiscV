# string_length.fas — Manual strlen vs Raven strlen syscall (1052)
#
# Implements the same measurement two ways and prints both results.
# They must agree — if they don't, something is wrong.
#
# Also compares instruction cost using get_instr_count (syscall 1030).

.data
msg:      .asciz "Hello, Raven!"
lbl_man:  .asciz "Manual  len="
lbl_sys:  .asciz "Syscall len="
lbl_cost: .asciz "  instrs="

.text
    # ── Method A: byte-by-byte walk ───────────────────────────────────────────
    li   a7, 1030
    ecall
    mv   s2, a0             # baseline count

    la   t0, msg
    li   s0, 0
manual_loop:
    lb   t1, 0(t0)
    beq  t1, zero, manual_done
    addi t0, t0, 1
    addi s0, s0, 1
    j    manual_loop
manual_done:

    li   a7, 1030
    ecall
    sub  s3, a0, s2

    li   a7, 1001
    la   a0, lbl_man
    ecall
    li   a7, 1000
    mv   a0, s0
    ecall
    li   a7, 1001
    la   a0, lbl_cost
    ecall
    li   a7, 1000
    mv   a0, s3
    ecall
    li   a7, 1008
    ecall

    # ── Method B: Raven strlen syscall 1052 ───────────────────────────────────
    li   a7, 1030
    ecall
    mv   s2, a0

    la   a0, msg
    li   a7, 1052           # strlen(a0) → a0
    ecall
    mv   s1, a0

    li   a7, 1030
    ecall
    sub  s3, a0, s2

    li   a7, 1001
    la   a0, lbl_sys
    ecall
    li   a7, 1000
    mv   a0, s1
    ecall
    li   a7, 1001
    la   a0, lbl_cost
    ecall
    li   a7, 1000
    mv   a0, s3
    ecall
    li   a7, 1008
    ecall

    li   a0, 0
    li   a7, 93
    ecall
