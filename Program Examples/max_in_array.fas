# max_in_array.fas — Find both minimum and maximum in a single O(n) pass
#
# The array is filled at run time via the Linux getrandom(2) syscall,
# so input differs on every execution.
# A naive approach uses two separate loops (2n comparisons).
# This version tracks both extremes simultaneously (n-1 comparisons after init).

.data
arr:     .space 40               # 10 × 4-byte slots, filled at run time
lbl_min: .asciz "min = "
lbl_max: .asciz "max = "

.text
    # Linux getrandom(2) — syscall 278:
    # fills the buffer with cryptographically-secure random bytes from
    # the kernel CSPRNG.  a0=buf, a1=len (bytes), a2=flags (0 = block
    # until the entropy pool is seeded; never returns stale data).
    la   a0, arr
    li   a1, 40                 # 10 elements × 4 bytes
    li   a2, 0
    li   a7, 278
    ecall

    # Reduce each raw 32-bit word to [1, 100] for readable output.
    la   t0, arr
    li   t1, 10
    li   t2, 0
reduce_loop:
    slli t3, t2, 2
    add  t3, t0, t3
    lw   t4, 0(t3)
    remu t4, t4, 100
    addi t4, t4, 1
    sw   t4, 0(t3)
    addi t2, t2, 1
    blt  t2, t1, reduce_loop

    la   t0, arr
    li   t1, 10             # length

    lw   s0, 0(t0)          # min = arr[0]
    lw   s1, 0(t0)          # max = arr[0]
    li   t2, 1              # i = 1

scan_loop:
    slli t3, t2, 2
    add  t3, t0, t3
    lw   t4, 0(t3)          # t4 = arr[i]

    bge  t4, s0, no_new_min
    mv   s0, t4             # new minimum found
no_new_min:
    ble  t4, s1, no_new_max
    mv   s1, t4             # new maximum found
no_new_max:
    addi t2, t2, 1
    blt  t2, t1, scan_loop

    # Print results
    li   a7, 1001
    la   a0, lbl_min
    ecall
    li   a7, 1000
    mv   a0, s0
    ecall
    li   a7, 1008
    ecall

    li   a7, 1001
    la   a0, lbl_max
    ecall
    li   a7, 1000
    mv   a0, s1
    ecall
    li   a7, 1008
    ecall

    li   a0, 0
    li   a7, 93
    ecall
