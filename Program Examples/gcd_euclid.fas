# gcd_euclid.fas — Interactive GCD via Euclid's algorithm
#
# Reads two positive integers from stdin (syscall 1013 = read_int).
# Computes gcd(a, b) iteratively: replace (a, b) with (b, a mod b) until b = 0.
# Also prints the step count so students can see how fast the algorithm converges.
#
# Example: gcd(252, 105) converges in 4 steps → 21

.data
lbl_a:    .asciz "a: "
lbl_b:    .asciz "b: "
lbl_gcd:  .asciz "gcd = "
lbl_step: .asciz "steps = "
a_buf:    .space 4
b_buf:    .space 4

.text
    li   a7, 1001
    la   a0, lbl_a
    ecall
    la   a0, a_buf
    li   a7, 1013           # read_int → stores i32 at a0
    ecall

    li   a7, 1001
    la   a0, lbl_b
    ecall
    la   a0, b_buf
    li   a7, 1013
    ecall

    la   t0, a_buf
    lw   s0, 0(t0)          # s0 = a
    la   t0, b_buf
    lw   s1, 0(t0)          # s1 = b
    li   s2, 0              # step counter

    # Euclidean algorithm: while b != 0: (a, b) = (b, a % b)
gcd_loop:
    beq  s1, zero, gcd_done
    remu t0, s0, s1         # t0 = a mod b
    mv   s0, s1             # a  = b
    mv   s1, t0             # b  = remainder
    addi s2, s2, 1
    j    gcd_loop
gcd_done:

    li   a7, 1001
    la   a0, lbl_gcd
    ecall
    li   a7, 1000
    mv   a0, s0
    ecall
    li   a7, 1008
    ecall

    li   a7, 1001
    la   a0, lbl_step
    ecall
    li   a7, 1000
    mv   a0, s2
    ecall
    li   a7, 1008
    ecall

    li   a0, 0
    li   a7, 93
    ecall
