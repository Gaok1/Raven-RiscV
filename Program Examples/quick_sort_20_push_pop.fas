.data
arr: .word 33, 12, 7, 25, 9, 13, 5, 1, 44, 3, 18, 2, 29, 8, 21, 6, 10, 17, 14, 4
msg: .asciz "Quicksort (20 elements) - recursise "
nl:  .byte 10, 0

.text
    printStrLn msg

    la a0, arr
    li a1, 0
    li a2, 19
    call quicksort

    # Print sorted array (one per line)
    la t0, arr
    li t4, 20
    li t1, 0
print_loop:
    slli t2, t1, 2
    add  t2, t0, t2
    lw   t3, 0(t2)
    print t3
    printStr nl
    addi t1, t1, 1
    blt  t1, t4, print_loop

    li a0, 0
    li a7, 93      # exit
    ecall


# quicksort(a0=base, a1=lo, a2=hi)
quicksort:
    bge a1, a2, qs_done

    push ra
    push s1
    push s2
    push s3
    push s4

    mv s1, a0      # base
    mv s2, a1      # lo
    mv s3, a2      # hi

    mv a0, s1
    mv a1, s2
    mv a2, s3
    call partition
    mv s4, a0      # pivotIndex

    # quicksort(base, lo, pivotIndex-1)
    mv a0, s1
    mv a1, s2
    addi a2, s4, -1
    call quicksort

    # quicksort(base, pivotIndex+1, hi)
    mv a0, s1
    addi a1, s4, 1
    mv a2, s3
    call quicksort

    pop s4
    pop s3
    pop s2
    pop s1
    pop ra

qs_done:
    ret


# partition(a0=base, a1=lo, a2=hi) -> a0 = pivotIndex
partition:
    push ra
    push s0
    push s1
    push s2
    push s3
    push s4
    push s5

    mv s1, a0      # base
    mv s2, a1      # lo
    mv s3, a2      # hi

    # pivot = arr[hi]
    slli t0, s3, 2
    add  t0, s1, t0
    lw   s0, 0(t0)

    addi s4, s2, -1 # i = lo - 1
    mv   s5, s2     # j = lo

part_loop:
    bge  s5, s3, part_done   # while (j < hi)

    # t1 = &arr[j]
    slli t1, s5, 2
    add  t1, s1, t1
    lw   t2, 0(t1)           # t2 = arr[j]

    # if (arr[j] > pivot) skip
    blt  s0, t2, skip_swap

    addi s4, s4, 1           # i++
    beq  s4, s5, skip_swap   # i == j => no swap

    # t3 = &arr[i]
    slli t3, s4, 2
    add  t3, s1, t3
    lw   t4, 0(t3)           # t4 = arr[i]

    sw   t2, 0(t3)           # arr[i] = arr[j]
    sw   t4, 0(t1)           # arr[j] = old arr[i]

skip_swap:
    addi s5, s5, 1
    j    part_loop

part_done:
    addi t0, s4, 1           # pivotIndex = i + 1

    # swap arr[pivotIndex] <-> arr[hi]
    slli t1, t0, 2
    add  t1, s1, t1
    lw   t2, 0(t1)           # arr[pivotIndex]

    slli t3, s3, 2
    add  t3, s1, t3
    lw   t4, 0(t3)           # arr[hi]

    sw   t4, 0(t1)
    sw   t2, 0(t3)

    mv a0, t0

    pop s5
    pop s4
    pop s3
    pop s2
    pop s1
    pop s0
    pop ra
    ret
