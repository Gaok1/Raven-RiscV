# selection_sort_20.fas — Selection sort on 20 integers
#
# Each outer pass finds the minimum of the unsorted suffix and moves it
# to its final position with exactly one swap.
#
# Complexity: O(n^2) comparisons, O(n) swaps — always exactly n-1 swaps
# regardless of input order.  Compare with bubble_sort_20.fas:
#   - Bubble: fewer swaps on nearly-sorted data (early-exit possible)
#   - Selection: constant swap count, simpler swap logic

.data
arr:        .word 12, 7, 25, 9, 13, 5, 1, 44, 3, 18, 2, 29, 8, 21, 6, 10, 17, 14, 4, 11
lbl_sorted: .asciz "Sorted: "
space:      .asciz " "

.text
    la   t0, arr
    li   t4, 20             # n
    li   t1, 0              # i = 0

outer:
    bge  t1, t4, print_result

    mv   t2, t1             # min_idx = i
    addi t3, t1, 1          # j = i+1

inner:
    bge  t3, t4, do_swap

    slli t5, t3, 2
    add  t5, t0, t5
    lw   s0, 0(t5)          # arr[j]

    slli t6, t2, 2
    add  t6, t0, t6
    lw   s1, 0(t6)          # arr[min_idx]

    bge  s0, s1, next_j
    mv   t2, t3             # found a new minimum

next_j:
    addi t3, t3, 1
    j    inner

do_swap:
    beq  t2, t1, no_swap    # minimum is already at position i

    slli t5, t1, 2
    add  t5, t0, t5
    lw   s0, 0(t5)          # arr[i]

    slli t6, t2, 2
    add  t6, t0, t6
    lw   s1, 0(t6)          # arr[min_idx]

    sw   s1, 0(t5)          # arr[i]      = old minimum
    sw   s0, 0(t6)          # arr[min_idx] = old arr[i]

no_swap:
    addi t1, t1, 1
    j    outer

print_result:
    li   a7, 1001
    la   a0, lbl_sorted
    ecall
    li   t2, 0
print_loop:
    slli t3, t2, 2
    add  t3, t0, t3
    lw   a0, 0(t3)
    li   a7, 1000
    ecall
    li   a7, 1001
    la   a0, space
    ecall
    addi t2, t2, 1
    blt  t2, t4, print_loop
    li   a7, 1008
    ecall

    li   a0, 0
    li   a7, 93
    ecall
