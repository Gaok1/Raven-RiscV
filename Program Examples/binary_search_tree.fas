# binary_search_tree.fas — BST with dynamic node allocation via brk
#
# Node layout (12 bytes):
#   +0  value  (i32)
#   +4  left   (ptr, 0 = NULL)
#   +8  right  (ptr, 0 = NULL)
#
# malloc() is a bump allocator over brk — extends the program break on each
# call.  See docs/memory-allocation.md for the full explanation.
#
# Operations:
#   insert  — recursive insertion preserving BST order
#   search  — iterative lookup (no stack needed)
#   inorder — recursive in-order traversal prints nodes sorted

.data
root:      .word 0               # root pointer (0 = empty tree)
lbl_ins:   .asciz "Inserting: 50 30 70 20 40 60 80\n"
lbl_trav:  .asciz "In-order:  "
lbl_found: .asciz "search(40) -> FOUND\n"
lbl_miss:  .asciz "search(99) -> NOT FOUND\n"
lbl_oom:   .asciz "out of memory\n"
space:     .asciz " "

.text
    # Print header via Linux write
    li   a0, 1
    la   a1, lbl_ins
    li   a2, 32
    li   a7, 64
    ecall

    la   s0, root           # s0 = &root (address of the root pointer)

    li   a1, 50
    mv   a0, s0
    call insert
    li   a1, 30
    mv   a0, s0
    call insert
    li   a1, 70
    mv   a0, s0
    call insert
    li   a1, 20
    mv   a0, s0
    call insert
    li   a1, 40
    mv   a0, s0
    call insert
    li   a1, 60
    mv   a0, s0
    call insert
    li   a1, 80
    mv   a0, s0
    call insert

    # In-order traversal (should print: 20 30 40 50 60 70 80)
    li   a7, 1001
    la   a0, lbl_trav
    ecall
    lw   a0, 0(s0)          # a0 = root node
    call inorder
    li   a7, 1008
    ecall

    # search(40) — present
    lw   a0, 0(s0)
    li   a1, 40
    call search
    li   a7, 1001
    la   a0, lbl_found
    ecall

    # search(99) — absent
    lw   a0, 0(s0)
    li   a1, 99
    call search
    bne  a0, zero, bst_end  # found (unexpected)
    li   a7, 1001
    la   a0, lbl_miss
    ecall

bst_end:
    li   a0, 0
    li   a7, 93
    ecall


# ── insert(a0 = &node_ptr, a1 = value) ───────────────────────────────────────
# Recursively walks the tree; allocates a new leaf when it reaches a NULL slot.
insert:
    lw   t0, 0(a0)          # t0 = current node (0 if NULL slot)
    bne  t0, zero, ins_walk

    # NULL slot: allocate a new node and link it here
    push ra
    push a0                 # save &node_ptr
    push a1                 # save value

    li   a0, 12
    call malloc             # a0 = pointer to fresh 12-byte node

    pop  a1                 # restore value
    pop  t2                 # restore &node_ptr
    pop  ra

    sw   a1, 0(a0)          # node.value = value
    sw   zero, 4(a0)        # node.left  = NULL
    sw   zero, 8(a0)        # node.right = NULL
    sw   a0, 0(t2)          # *node_ptr  = new node
    ret

ins_walk:
    push ra
    push s0
    push s1

    mv   s0, t0             # s0 = current node pointer
    mv   s1, a1             # s1 = value to insert

    lw   t1, 0(s0)          # t1 = node.value
    blt  s1, t1, ins_left

    addi a0, s0, 8          # &node.right
    mv   a1, s1
    call insert
    j    ins_done

ins_left:
    addi a0, s0, 4          # &node.left
    mv   a1, s1
    call insert

ins_done:
    pop  s1
    pop  s0
    pop  ra
    ret


# ── inorder(a0 = node_ptr) ───────────────────────────────────────────────────
# Recursive in-order: visit left, print value, visit right.
inorder:
    beq  a0, zero, inorder_ret

    push ra
    push s0
    mv   s0, a0             # s0 = current node

    lw   a0, 4(s0)          # left child
    call inorder

    lw   a0, 0(s0)          # node value
    li   a7, 1000           # print_int
    ecall
    li   a7, 1001
    la   a0, space
    ecall

    lw   a0, 8(s0)          # right child
    call inorder

    pop  s0
    pop  ra
inorder_ret:
    ret


# ── search(a0 = node, a1 = value) → a0 = matching node or 0 ─────────────────
# Iterative — no stack frame needed for a simple walk.
search:
search_loop:
    beq  a0, zero, search_ret       # NULL → not found
    lw   t0, 0(a0)                  # node.value
    beq  t0, a1, search_ret        # match → return node (a0 unchanged)
    blt  a1, t0, search_left
    lw   a0, 8(a0)                  # go right
    j    search_loop
search_left:
    lw   a0, 4(a0)                  # go left
    j    search_loop
search_ret:
    ret


# ── malloc(a0 = size) → a0 = ptr ─────────────────────────────────────────────
# Bump allocator backed by brk.  Never frees memory (no free in this demo).
malloc:
    push ra
    mv   t2, a0             # t2 = requested size

    li   a0, 0              # brk(0) queries the current program break
    li   a7, 214
    ecall
    mv   t1, a0             # t1 = old break = start of the new block

    add  a0, t1, t2         # request break extension
    li   a7, 214
    ecall

    add  t3, t1, t2         # t3 = expected new break
    bge  a0, t3, malloc_ok  # Raven accepted → proceed
    li   a7, 1001           # Raven refused → OOM
    la   a0, lbl_oom
    ecall
    li   a0, 1
    li   a7, 93
    ecall

malloc_ok:
    mv   a0, t1             # return old break (start of allocated block)
    pop  ra
    ret
