# cache_conflict.fas — Cache conflict-miss demonstration
#
# Accesses two (Phase A) or three (Phase B) memory lines that map to the
# SAME cache set under the default config (1 KB capacity / 16 B lines / 2-way).
#
# Why they conflict: lines 512 bytes apart share a set because
#   set_index = (address / line_size) % num_sets
# With 16 B lines and 64 sets: offset 0, 512, 1024 all land in set 0.
#
# Phase A: 2 lines — fits in a 2-way set; both stay resident → high hit rate.
# Phase B: 3 lines — exceeds 2-way capacity; each access evicts one of the
#          others → every access is a miss (cache thrashing).
#
# How to use:
#   1. Open the Cache tab → Stats panel.
#   2. Click [Reset] to clear counters.
#   3. Press Enter in the console to start the phase.
#   4. Read hit-rate and miss-rate in Stats.

.data
title:   .asciz "CACHE: Conflict misses (same set)"
phase_a: .asciz "Phase A: 2 lines — 2-way holds both, expect high hit rate."
phase_b: .asciz "Phase B: 3 lines — 2-way thrashes, expect ~0% hit rate."
howto:   .asciz "Reset Cache -> Stats, then press Enter."
done:    .asciz "Done."
wbuf:    .space 64

.align 16
buf: .space 1536            # offsets 0, 512, 1024 all map to the same cache set

.text
    printStrLn title

    # ── Phase A: two lines ────────────────────────────────────────────────────
    printStrLn phase_a
    printStrLn howto
    read wbuf

    la   t0, buf
    addi t1, t0, 0          # line 0: buf + 0
    addi t2, t0, 512        # line 1: buf + 512  (same set)
    li   t3, 20000
loop_a:
    lw   t4, 0(t1)
    lw   t5, 0(t2)
    addi t3, t3, -1
    bne  t3, zero, loop_a

    # ── Phase B: three lines ──────────────────────────────────────────────────
    printStrLn phase_b
    printStrLn howto
    read wbuf

    addi t6, t0, 1024       # line 2: buf + 1024 (same set → causes thrash)
    li   t3, 20000
loop_b:
    lw   t4, 0(t1)
    lw   t5, 0(t2)
    lw   s0, 0(t6)
    addi t3, t3, -1
    bne  t3, zero, loop_b

    printStrLn done
    li   a0, 0
    li   a7, 93
    ecall
