# R300 - perfil geral para D3
# Cache habilitada, pipeline desligado, 1 hart em foco, sem trace de syscalls.
# Os arquivos C3xx.fcache definem a geometria/politica detalhada da cache.
cache_enabled=true
pipeline_enabled=false
trace_syscalls=false
mem_kb=16384
max_cores=1
run_scope=focus

# CPI (cycles per instruction)
cpi.alu=1
cpi.mul=3
cpi.div=20
cpi.load=0
cpi.store=0
cpi.branch_taken=3
cpi.branch_not_taken=1
cpi.jump=2
cpi.system=10
cpi.fp=5
