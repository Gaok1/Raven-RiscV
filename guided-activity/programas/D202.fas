##! D202 — Flush por redirecionamento de controle
##! O jal volta para o loop e a instrucao logo abaixo deve ser descartada.
##! Compare este comportamento com o stall do D201.

.data
msg_ok: .asciz "Flush correto: s1 = 0"

.text
    li   s0, 0         # iteracoes confirmadas
    li   s1, 0         # contador do caminho errado (deve ficar 0)
    li   t0, 6

loop:
    beq  t0, zero, done
    addi s0, s0, 1
    addi t0, t0, -1
    jal  zero, loop        #! redireciona o PC
    addi s1, s1, 99        #! caminho errado: deve ser descartado

done:
    printStrLn msg_ok
    li   a0, 0
    li   a7, 93
    ecall
